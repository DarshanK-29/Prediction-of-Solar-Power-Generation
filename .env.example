# OpenWeatherMap API Key
# Get your free API key from: https://openweathermap.org/api
# Replace 'your_api_key_here' with your actual API key
OPENWEATHER_API_KEY=your_api_key_here

# NASA API Key (Optional - for satellite data integration)
# Get your free API key from: https://api.nasa.gov/
# Replace 'your_nasa_api_key_here' with your actual NASA API key
NASA_API_KEY=your_nasa_api_key_here

# Earthdata Login Credentials (Optional - for MODIS satellite data)
# Register at: https://urs.earthdata.nasa.gov/
# Replace with your actual Earthdata username and password
EARTHDATA_USERNAME=your_earthdata_username
EARTHDATA_PASSWORD=your_earthdata_password